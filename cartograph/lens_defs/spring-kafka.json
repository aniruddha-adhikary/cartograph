[
  {
    "name": "spring-kafka-consumer",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "regex",
      "patterns": [
        {
          "regex": "@KafkaListener\\s*\\(\\s*topics\\s*=\\s*\"(?P<topic>[^\"]+)\"",
          "per_line": true
        }
      ]
    },
    "emit": {
      "label": "KafkaConsumer",
      "schema": {
        "message_role": "string",
        "bus": "string",
        "topic": "string",
        "topics": "list"
      },
      "values": {
        "message_role": "consumer",
        "bus": "kafka",
        "topic": "{{topic}}",
        "topics": [
          "{{topic}}"
        ]
      },
      "source": "lens:spring-kafka",
      "confidence": "high"
    }
  },
  {
    "name": "spring-kafka-producer",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "tree-sitter",
      "tree_sitter": {
        "language": "java",
        "extractor": "method-call",
        "method_name": "send",
        "arg_index": 0,
        "capture_as": "topic",
        "receiver_types": [
          "KafkaTemplate",
          "ReactiveKafkaProducerTemplate"
        ]
      }
    },
    "emit": {
      "label": "KafkaProducer",
      "schema": {
        "message_role": "string",
        "bus": "string",
        "topic": "string"
      },
      "values": {
        "message_role": "producer",
        "bus": "kafka",
        "topic": "{{topic}}",
        "delivery_edge": "KAFKA_DELIVERS"
      },
      "source": "lens:spring-kafka",
      "confidence": "high"
    }
  }
]
