[
  {
    "name": "mp-reactive-messaging-incoming",
    "scope": "source",
    "match": {
      "files": ["*.java"],
      "strategy": "tree-sitter",
      "tree_sitter": {
        "language": "java",
        "extractor": "query",
        "anchor": "anchor",
        "query": "(class_declaration name: (identifier) @class_name body: (class_body (method_declaration (modifiers (annotation name: (identifier) @ann (#eq? @ann \"Incoming\") arguments: (annotation_argument_list (string_literal (string_fragment) @channel)))) name: (identifier) @method_name) @anchor))"
      }
    },
    "emit": {
      "label": "MessageConsumer",
      "schema": {
        "message_role": "string",
        "bus": "string",
        "channel": "string",
        "topic": "string",
        "topics": "list",
        "handler": "string",
        "framework": "string"
      },
      "values": {
        "message_role": "consumer",
        "bus": "mp-reactive-messaging",
        "channel": "{{channel}}",
        "topic": "{{channel}}",
        "topics": ["{{channel}}"],
        "handler": "{{class_name}}.{{method_name}}",
        "framework": "mp-reactive-messaging"
      },
      "source": "lens:microprofile-reactive-messaging",
      "confidence": "high"
    }
  },
