[
  {
    "name": "cassandra-java-session-execute",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "token-line",
      "tokens": [
        ".execute(\""
      ],
      "extract": "\\.execute\\(\\s*\"(?P<query>(?P<operation>SELECT|INSERT|UPDATE|DELETE)\\b[^\"]*?\\bFROM\\s+(?P<table>[\\w.]+)[^\"]*)\""
    },
    "emit": {
      "label": "DatabaseQuery",
      "schema": {
        "operation": "string",
        "table": "string",
        "query": "string",
        "dialect": "string",
        "framework": "string"
      },
      "values": {
        "operation": "{{operation}}",
        "table": "{{table}}",
        "query": "{{query}}",
        "dialect": "cql",
        "framework": "cassandra-java"
      },
      "source": "lens:cassandra-java",
      "confidence": "medium"
    }
  },
