  {
    "name": "cassandra-java-table-annotation",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "regex",
      "patterns": [
        {
          "regex": "@Table\\s*\\(\\s*(?:keyspace\\s*=\\s*\"(?P<keyspace>[^\"]+)\"\\s*,\\s*)?name\\s*=\\s*\"(?P<table>[^\"]+)\"",
          "per_line": false,
          "gate": "(?:com\\.datastax|driver\\.api\\.mapper|\\bMappedClass\\b)"
        }
      ]
    },
    "emit": {
      "label": "DatabaseTable",
      "schema": {
        "name": "string",
        "keyspace": "string",
        "dialect": "string",
        "framework": "string"
      },
      "values": {
        "name": "{{table}}",
        "keyspace": "{{keyspace|}}",
        "dialect": "cql",
        "framework": "cassandra-java"
      },
      "source": "lens:cassandra-java",
      "confidence": "high"
    }
  },
  {
    "name": "cassandra-cql-create-table",
    "scope": "source",
    "match": {
      "files": [
        "*.cql"
      ],
      "strategy": "regex",
      "patterns": [
        {
          "regex": "CREATE\\s+TABLE\\s+(?:IF\\s+NOT\\s+EXISTS\\s+)?(?P<table>[\\w.]+)",
          "per_line": true
        }
      ]
    },
    "emit": {
      "label": "DatabaseTable",
      "schema": {
        "name": "string",
        "dialect": "string",
        "framework": "string"
      },
      "values": {
        "name": "{{table}}",
        "dialect": "cql",
        "framework": "cassandra-java"
      },
      "source": "lens:cassandra-java",
      "confidence": "high"
    }
  }
