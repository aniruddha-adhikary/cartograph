[
  {
    "name": "angular-component",
    "scope": "source",
    "match": {
      "files": [
        "*.ts"
      ],
      "strategy": "regex",
      "patterns": [
        {
          "regex": "@Component\\s*\\(\\s*\\{[^}]*?\\bselector\\s*:\\s*['\"`](?P<selector>[^'\"`]+)['\"`]",
          "per_line": false
        }
      ]
    },
    "emit": {
      "label": "Component",
      "schema": {
        "name": "string",
        "kind": "string",
        "framework": "string",
        "selector": "string"
      },
      "values": {
        "name": "{{_file_stem}}",
        "kind": "component",
        "framework": "angular",
        "selector": "{{selector}}"
      },
      "source": "lens:angular-component",
      "confidence": "high"
    }
  },
