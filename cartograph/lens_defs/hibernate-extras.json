    "name": "hibernate-entity-behavior-marker",
    "scope": "source",
    "match": {
      "files": ["*.java"],
      "strategy": "tree-sitter",
      "tree_sitter": {
        "language": "java",
        "extractor": "query",
        "anchor": "anchor",
        "query": "(class_declaration (modifiers (marker_annotation name: (identifier) @ann (#match? @ann \"^(DynamicInsert|DynamicUpdate|Immutable)$\"))) name: (identifier) @class_name) @anchor"
      }
    },
    "emit": {
      "label": "EntityBehavior",
      "schema": {"kind": "string", "owner_class": "string", "framework": "string"},
      "values": {
        "kind": "{{ann}}",
        "owner_class": "{{class_name}}",
        "framework": "hibernate"
      },
      "source": "lens:hibernate-extras",
      "confidence": "high"
    }
  },
