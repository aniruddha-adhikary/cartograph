[
  {
    "name": "dropwizard-managed-component",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "regex",
      "patterns": [
        {
          "regex": "environment\\s*\\.\\s*lifecycle\\s*\\(\\s*\\)\\s*\\.\\s*manage\\s*\\(\\s*(?:new\\s+(?P<component_type>[A-Z]\\w+)\\s*\\(|(?P<component_ref>[a-zA-Z_]\\w*))",
          "per_line": false
        }
      ]
    },
    "emit": {
      "label": "ManagedComponent",
      "schema": {
        "name": "string",
        "kind": "string",
        "framework": "string"
      },
      "values": {
        "name": "{{component_type|component_ref|}}",
        "kind": "dropwizard-managed",
        "framework": "dropwizard"
      },
      "source": "lens:dropwizard",
      "confidence": "medium"
    }
  },
  {
    "name": "dropwizard-healthcheck-register",
    "scope": "source",
