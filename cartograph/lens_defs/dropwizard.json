          "regex": "environment\\s*\\.\\s*admin\\s*\\(\\s*\\)\\s*\\.\\s*addTask\\s*\\(\\s*new\\s+\\w*Task\\s*\\(\\s*\"(?P<name>[^\"]+)\"",
          "per_line": false
