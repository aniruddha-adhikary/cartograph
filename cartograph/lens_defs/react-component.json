{
  "name": "react-component",
  "scope": "source",
  "match": {
    "files": ["*.js", "*.jsx", "*.ts", "*.tsx"],
    "strategy": "regex",
    "patterns": [
      {
        "regex": "(?:function\\s+(?P<name1>[A-Z]\\w+)|const\\s+(?P<name2>[A-Z]\\w+)\\s*=|class\\s+(?P<name3>[A-Z]\\w+)\\s+extends\\s+React\\.Component)",
        "per_line": true
      }
    ]
  },
  "emit": {
    "label": "Component",
    "schema": {
      "name": "string",
      "kind": "string"
    },
    "values": {
      "name": "{{name1}}{{name2}}{{name3}}",
      "kind": "react-component"
    },
    "source": "lens:react-component",
    "confidence": "high"
  }
}
