{
  "name": "react-component",
  "scope": "source",
  "match": {
    "files": ["*.jsx", "*.tsx"],
    "strategy": "regex",
    "patterns": [
      {
        "regex": "(?:export\\s+(?:default\\s+)?(?:function\\s+(?P<fn_name>[A-Z]\\w+)|const\\s+(?P<const_name>[A-Z]\\w+)\\s*[:=])|class\\s+(?P<class_name>[A-Z]\\w+)\\s+extends\\s+(?:React\\.)?(?:Component|PureComponent))",
        "per_line": true
      }
    ]
  },
  "emit": {
    "label": "Component",
    "schema": {
      "name": "string",
      "kind": "string"
    },
    "values": {
      "name": "{{fn_name|const_name|class_name}}",
      "kind": "react-component"
    },
    "source": "lens:react-component",
    "confidence": "medium"
  }
}
