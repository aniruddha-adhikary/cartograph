[
  {
    "name": "jdbc-callable-statement-prepare-call",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "token-line",
      "tokens": [
        ".prepareCall("
      ],
      "extract": "\"\\s*\\{\\s*(?:\\?\\s*=\\s*)?call\\s+(?P<proc_name>[A-Za-z_][\\w.$]*)\\s*\\("
    },
    "emit": {
      "label": "StoredProcedureCall",
      "schema": {
        "proc_name": "string",
        "framework": "string",
        "kind": "string",
        "delivery_edge": "string",
        "target_label": "string"
      },
      "values": {
        "proc_name": "{{proc_name}}",
        "framework": "jdbc",
        "kind": "callable-statement",
        "delivery_edge": "EXECUTES_PROCEDURE",
        "target_label": "StoredProcedure"
      },
      "source": "lens:jdbc-stored-procedure",
      "confidence": "high"
    }
  },
  {
    "name": "jdbc-stored-procedure-target",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "token-line",
      "tokens": [
        ".prepareCall("
      ],
      "extract": "\"\\s*\\{\\s*(?:\\?\\s*=\\s*)?call\\s+(?P<proc_name>[A-Za-z_][\\w.$]*)\\s*\\("
    },
    "emit": {
      "label": "StoredProcedure",
      "schema": {
