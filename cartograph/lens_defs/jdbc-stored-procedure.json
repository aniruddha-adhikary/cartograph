        "framework": "string"
      },
      "values": {
        "name": "{{proc_name}}",
        "framework": "jdbc"
      },
      "source": "lens:jdbc-stored-procedure",
      "confidence": "high"
    }
  },
  {
    "name": "jpa-named-stored-procedure-query",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "regex",
      "patterns": [
        {
          "regex": "@NamedStoredProcedureQuery\\s*\\((?P<args>[^)]*name\\s*=\\s*\"(?P<query_name>[^\"]+)\"[^)]*procedureName\\s*=\\s*\"(?P<proc_name>[^\"]+)\"[^)]*)\\)",
          "per_line": false
        }
      ]
    },
    "emit": {
      "label": "StoredProcedureCall",
      "schema": {
        "query_name": "string",
        "proc_name": "string",
        "framework": "string",
        "kind": "string",
        "args": "string",
        "delivery_edge": "string",
        "target_label": "string"
      },
      "values": {
        "query_name": "{{query_name}}",
        "proc_name": "{{proc_name}}",
        "framework": "jpa",
        "kind": "named-stored-procedure-query",
        "args": "{{args}}",
        "delivery_edge": "EXECUTES_PROCEDURE",
        "target_label": "StoredProcedure"
      },
      "source": "lens:jdbc-stored-procedure",
      "confidence": "high"
    }
  },
  {
