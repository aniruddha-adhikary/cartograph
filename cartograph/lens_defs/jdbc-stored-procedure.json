  {
    "name": "jpa-procedure-annotation",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "tree-sitter",
      "tree_sitter": {
        "language": "java",
        "extractor": "query",
        "anchor": "anchor",
        "query": "(method_declaration (modifiers (annotation name: (_) @ann (#match? @ann \"(^|\\\\.)Procedure$\") arguments: (annotation_argument_list) @args_text)) name: (identifier) @method_name) @anchor"
      }
    },
    "emit": {
      "label": "StoredProcedureCall",
      "schema": {
        "query_name": "string",
        "proc_name": "string",
        "framework": "string",
        "kind": "string",
        "args_text": "string",
        "delivery_edge": "string",
        "target_label": "string"
      },
      "values": {
        "query_name": "{{method_name}}",
        "proc_name": "",
        "framework": "spring-data-jpa",
        "kind": "procedure-annotation",
        "args_text": "{{args_text}}",
        "delivery_edge": "EXECUTES_PROCEDURE",
        "target_label": "StoredProcedure"
      },
      "source": "lens:jdbc-stored-procedure",
      "confidence": "high"
    }
  },
  {
    "name": "jpa-procedure-resolve-proc-name",
    "scope": "resolve",
    "match": {
      "label": "StoredProcedureCall",
      "field": "args_text",
      "pattern": "procedureName\\s*=\\s*\"(?P<pn>[^\"]+)\""
    },
    "set": {
      "proc_name": "{{pn}}"
    }
  },
  {
    "name": "jpa-procedure-resolve-bare",
    "scope": "resolve",
    "match": {
      "label": "StoredProcedureCall",
      "field": "args_text",
      "pattern": "^\\(\\s*\"(?P<pn>[^\"]+)\"\\s*\\)$"
    },
    "set": {
      "proc_name": "{{pn}}"
    }
  }
]
