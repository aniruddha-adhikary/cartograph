          "regex": "@NamedStoredProcedureQuery\\s*\\((?P<args>[^)]*procedureName\\s*=\\s*\"(?P<proc_name>[^\"]+)\"[^)]*name\\s*=\\s*\"(?P<query_name>[^\"]+)\"[^)]*)\\)",
          "per_line": false
        }
      ]
    },
    "emit": {
