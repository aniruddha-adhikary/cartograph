{
  "name": "js-http-call",
  "scope": "source",
  "match": {
    "files": ["*.js", "*.ts", "*.jsx", "*.tsx"],
    "strategy": "token-line",
    "tokens": ["fetch(", "axios."],
    "extract": "[`'\"](?P<url>https?://[^`'\"]+|/[A-Za-z0-9_./{}-]+)['\"`]"
  },
  "emit": {
    "label": "HttpCall",
    "schema": {
      "url": "string",
      "http_method": "string"
    },
    "values": {
      "url": "{{url}}",
      "http_method": "GET"
    },
    "source": "lens:js-http-call",
    "confidence": "high"
  }
}
