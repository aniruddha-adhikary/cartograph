        "anchor": "anchor",
        "query": "(interface_declaration name: (identifier) @class_name (extends_interfaces (type_list (generic_type (type_identifier) @base (#match? @base \"^(JpaRepository|CrudRepository|PagingAndSortingRepository|ReactiveCrudRepository|MongoRepository|JpaSpecificationExecutor|QuerydslPredicateExecutor)$\"))))) @anchor (interface_declaration name: (identifier) @class_name (extends_interfaces (type_list (type_identifier) @base (#match? @base \"^(JpaRepository|CrudRepository|PagingAndSortingRepository|ReactiveCrudRepository|MongoRepository|JpaSpecificationExecutor|QuerydslPredicateExecutor)$\")))) @anchor"
      }
