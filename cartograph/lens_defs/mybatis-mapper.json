  {
    "name": "mybatis-mapper-interface",
    "scope": "source",
    "match": {
      "files": ["*.java"],
      "strategy": "tree-sitter",
      "tree_sitter": {
        "language": "java",
        "extractor": "query",
        "anchor": "anchor",
        "query": "(interface_declaration (modifiers (marker_annotation name: (identifier) @ann (#eq? @ann \"Mapper\"))) name: (identifier) @class_name) @anchor"
      }
    },
    "emit": {
      "label": "Component",
      "schema": {"name": "string", "kind": "string", "framework": "string"},
      "values": {
        "name": "{{class_name}}",
        "kind": "mybatis-mapper",
        "framework": "mybatis"
      },
      "source": "lens:mybatis-mapper",
      "confidence": "high"
    }
  },
