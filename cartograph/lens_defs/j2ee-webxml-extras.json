[
  {
    "name": "j2ee-webxml-security-constraint",
    "scope": "source",
    "match": {
      "files": ["web.xml"],
      "strategy": "xml-query",
      "select": ".//security-constraint",
      "captures": {
        "web_resource_name": "web-resource-collection/web-resource-name",
        "url_pattern": "web-resource-collection/url-pattern",
        "http_method": "web-resource-collection/http-method",
        "role_name": "auth-constraint/role-name"
      }
    },
    "emit": {
      "label": "SecurityConstraint",
      "schema": {
        "web_resource_name": "string", "url_pattern": "string", "http_method": "string",
        "role_name": "string", "framework": "string"
      },
      "values": {
        "web_resource_name": "{{web_resource_name}}",
        "url_pattern": "{{url_pattern}}",
        "http_method": "{{http_method}}",
        "role_name": "{{role_name}}",
        "framework": "j2ee-webxml"
      },
      "source": "lens:j2ee-webxml-extras",
      "confidence": "high"
    }
  },
  {
