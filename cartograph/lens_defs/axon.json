        "topic": "string",
        "event_type": "string",
        "operation": "string",
        "framework": "string",
        "delivery_edge": "string"
      },
      "values": {
        "message_role": "producer",
        "bus": "axon-event-bus",
        "topic": "{{event_type}}",
        "event_type": "{{event_type}}",
        "operation": "{{eb_op}}",
        "framework": "axon",
        "delivery_edge": "MESSAGE_DELIVERS"
      },
      "source": "lens:axon",
