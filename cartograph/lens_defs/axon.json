      "strategy": "regex",
      "patterns": [
        {
          "regex": "(?:eventBus|eventGateway)\\s*\\.\\s*(?P<eb_op>publish|publishEvent)\\s*\\(\\s*new\\s+(?P<event_type>[A-Z]\\w+)\\s*\\(",
          "per_line": false
        }
      ]
    },
    "emit": {
      "label": "MessageProducer",
