[
  {
    "name": "axon-command-handler",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "tree-sitter",
      "tree_sitter": {
        "language": "java",
        "extractor": "query",
        "anchor": "anchor",
        "query": "(class_declaration name: (identifier) @class_name body: (class_body (method_declaration (modifiers (marker_annotation name: (identifier) @ann (#eq? @ann \"CommandHandler\"))) name: (identifier) @method_name) @anchor)) (class_declaration name: (identifier) @class_name body: (class_body (method_declaration (modifiers (annotation name: (identifier) @ann (#eq? @ann \"CommandHandler\"))) name: (identifier) @method_name) @anchor))"
      }
    },
    "emit": {
      "label": "CommandHandler",
      "schema": {
        "class_name": "string",
        "method_name": "string",
        "handler": "string",
        "framework": "string",
        "bus": "string"
      },
      "values": {
        "class_name": "{{class_name}}",
        "method_name": "{{method_name}}",
        "handler": "{{class_name}}.{{method_name}}",
        "framework": "axon",
        "bus": "axon-command-bus"
      },
      "source": "lens:axon",
      "confidence": "high"
    }
  },
  {
