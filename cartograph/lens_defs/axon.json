      "values": {
        "class_name": "{{class_name}}",
        "method_name": "{{method_name}}",
        "handler": "{{class_name}}.{{method_name}}",
        "event_type": "{{event_type}}",
        "annotation": "{{ann}}",
        "framework": "axon",
        "bus": "axon-event-bus"
      },
      "source": "lens:axon",
      "confidence": "high"
    }
  },
  {
