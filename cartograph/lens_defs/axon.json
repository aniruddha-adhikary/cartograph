  {
    "name": "axon-command-gateway-send",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "regex",
      "patterns": [
        {
          "regex": "commandGateway\\s*\\.\\s*(?P<gw_op>send|sendAndWait)\\s*\\(\\s*new\\s+(?P<command_type>[A-Z]\\w+)\\s*\\(",
          "per_line": false
        }
      ]
    },
    "emit": {
      "label": "MessageProducer",
      "schema": {
        "message_role": "string",
        "bus": "string",
        "topic": "string",
        "command_type": "string",
        "operation": "string",
        "framework": "string",
        "delivery_edge": "string"
      },
      "values": {
        "message_role": "producer",
        "bus": "axon-command-bus",
        "topic": "{{command_type}}",
        "command_type": "{{command_type}}",
        "operation": "{{gw_op}}",
        "framework": "axon",
        "delivery_edge": "MESSAGE_DELIVERS"
      },
      "source": "lens:axon",
      "confidence": "medium"
    }
  },
  {
    "name": "axon-event-bus-publish",
    "scope": "source",
