        "extractor": "query",
        "anchor": "anchor",
        "query": "(class_declaration (modifiers (marker_annotation name: (identifier) @ann (#eq? @ann \"Aggregate\"))) name: (identifier) @class_name) @anchor (class_declaration (modifiers (annotation name: (identifier) @ann (#eq? @ann \"Aggregate\"))) name: (identifier) @class_name) @anchor"
