[
  {
    "name": "spring-data-redis-enable",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "regex",
      "patterns": [
        {
          "regex": "@EnableRedisRepositories\\b",
          "per_line": true,
          "gate": "class\\s+(?P<class_name>\\w+)"
        }
      ]
    },
    "emit": {
      "label": "Component",
      "schema": {
        "kind": "string",
        "framework": "string",
        "name": "string"
      },
      "values": {
        "kind": "spring-data-redis-config",
        "framework": "spring-data-redis",
        "name": "{{class_name}}"
      },
      "source": "lens:spring-data-redis",
      "confidence": "high"
    }
  },
  {
    "name": "spring-data-redis-hash-entity",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "regex",
      "patterns": [
        {
          "regex": "@RedisHash\\s*(?:\\(\\s*(?:value\\s*=\\s*)?\"(?P<keyspace>[^\"]+)\"\\s*\\))?",
          "per_line": false,
          "gate": "class\\s+(?P<class_name>\\w+)"
        }
      ]
    },
    "emit": {
      "label": "Component",
      "schema": {
        "kind": "string",
        "framework": "string",
        "name": "string",
        "keyspace": "string"
      },
      "values": {
        "kind": "redis-hash-entity",
        "framework": "spring-data-redis",
        "name": "{{class_name}}",
        "keyspace": "{{keyspace}}"
      },
      "source": "lens:spring-data-redis",
      "confidence": "high"
    }
  },
  {
    "name": "spring-data-redis-template-ops",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "tree-sitter",
      "tree_sitter": {
        "language": "java",
        "extractor": "query",
        "anchor": "anchor",
        "query": "(method_invocation name: (identifier) @ops_method (#match? @ops_method \"^(opsForValue|opsForList|opsForHash|opsForSet|opsForZSet|opsForStream|opsForGeo|opsForHyperLogLog)$\")) @anchor"
      }
    },
    "emit": {
      "label": "CacheOperation",
      "schema": {
        "kind": "string",
        "framework": "string",
        "ops_method": "string",
        "cache": "string"
      },
      "values": {
        "kind": "redis-template",
        "framework": "spring-data-redis",
        "ops_method": "{{ops_method}}",
        "cache": "redis"
      },
      "source": "lens:spring-data-redis",
      "confidence": "medium"
    }
  }
]
