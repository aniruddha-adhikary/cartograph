[
  {
    "name": "vertx-router-method",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "regex",
      "patterns": [
        {
          "regex": "router\\s*\\.\\s*(?P<http_verb>get|post|put|delete|patch|head|options)\\s*\\(\\s*\"(?P<path>[^\"]+)\"\\s*\\)",
          "per_line": false
        }
      ]
    },
    "emit": {
      "label": "Endpoint",
      "schema": {
        "http_method": "string",
        "path": "string",
        "framework": "string",
        "handler": "string"
      },
      "values": {
        "http_method": "{{http_verb}}",
        "path": "{{path}}",
        "framework": "vertx",
        "handler": ""
      },
      "source": "lens:vertx",
      "confidence": "medium"
    }
  },
