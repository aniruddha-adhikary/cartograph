[
  {
    "name": "rabbitmq-java-direct-publish",
    "scope": "source",
    "match": {
      "files": [
        "*.java"
      ],
      "strategy": "token-line",
      "tokens": [
        ".basicPublish("
      ],
      "extract": "\\.basicPublish\\(\\s*\"(?P<exchange>[^\"]*)\"\\s*,\\s*\"(?P<routing_key>[^\"]*)\""
    },
    "emit": {
      "label": "MessageProducer",
      "schema": {
        "message_role": "string",
        "bus": "string",
        "topic": "string",
        "exchange": "string",
        "routing_key": "string",
        "framework": "string",
        "delivery_edge": "string"
      },
      "values": {
        "message_role": "producer",
        "bus": "amqp",
        "topic": "{{exchange}}",
        "exchange": "{{exchange}}",
        "routing_key": "{{routing_key}}",
        "framework": "rabbitmq-java-direct",
        "delivery_edge": "MESSAGE_DELIVERS"
      },
      "source": "lens:rabbitmq-java-direct",
      "confidence": "high"
    }
  },
