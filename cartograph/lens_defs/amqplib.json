[
  {
    "name": "amqplib-publish",
    "scope": "source",
    "match": {
      "files": [
        "*.js",
        "*.ts",
        "*.mjs",
        "*.cjs"
      ],
      "strategy": "token-line",
      "tokens": [
        ".publish("
      ],
      "extract": "\\.publish\\s*\\(\\s*['\"`](?P<exchange>[^'\"`]+)['\"`]\\s*,\\s*['\"`](?P<routing_key>[^'\"`]*)['\"`]",
      "import_gate": [
        "amqplib"
      ]
    },
    "emit": {
      "label": "MessageProducer",
      "schema": {
        "message_role": "string",
        "bus": "string",
        "exchange": "string",
        "routing_key": "string",
        "topic": "string",
        "framework": "string",
        "delivery_edge": "string"
      },
      "values": {
        "message_role": "producer",
        "bus": "amqp",
        "exchange": "{{exchange}}",
        "routing_key": "{{routing_key}}",
        "topic": "{{exchange}}",
        "framework": "amqplib",
        "delivery_edge": "MESSAGE_DELIVERS"
      },
      "source": "lens:amqplib",
      "confidence": "high"
    }
  },
