  {
    "name": "j2ee-webxml-servlet",
    "scope": "source",
    "match": {
      "files": ["web.xml"],
      "strategy": "xml-query",
      "select": ".//servlet",
      "captures": {
        "servlet_name": "servlet-name",
        "class_name": "servlet-class"
      }
    },
    "emit": {
      "label": "Servlet",
      "schema": {"name": "string", "class_name": "string", "framework": "string"},
      "values": {
        "name": "{{servlet_name}}",
        "class_name": "{{class_name}}",
        "framework": "j2ee-webxml"
      },
      "source": "lens:j2ee-descriptors",
      "confidence": "high"
    }
  },
