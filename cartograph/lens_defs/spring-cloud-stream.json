[
  {
    "name": "spring-cloud-stream-functional-bean",
    "scope": "source",
    "match": {
      "files": ["*.java"],
      "strategy": "tree-sitter",
      "tree_sitter": {
        "language": "java",
        "extractor": "query",
        "anchor": "anchor",
        "query": "(method_declaration (modifiers (marker_annotation name: (identifier) @ann (#eq? @ann \"Bean\"))) type: (generic_type (type_identifier) @kind (#match? @kind \"^(Supplier|Function|Consumer)$\")) name: (identifier) @bean_name) @anchor"
      }
    },
    "emit": {
      "label": "StreamFunction",
      "schema": {
        "kind": "string",
        "bean_name": "string",
        "framework": "string"
      },
      "values": {
        "kind": "{{kind}}",
        "bean_name": "{{bean_name}}",
        "framework": "spring-cloud-stream"
      },
      "source": "lens:spring-cloud-stream",
      "confidence": "high"
    }
  },
  {
    "name": "spring-cloud-stream-binding-destination",
    "scope": "source",
    "match": {
      "files": ["*.properties", "*.yaml", "*.yml"],
      "strategy": "config-key",
      "key_pattern": "spring\\.cloud\\.stream\\.bindings\\.(?P<binding_name>[\\w.-]+)\\.destination\\s*[:=]\\s*(?P<destination>\\S+)"
    },
    "emit": {
      "label": "StreamBinding",
      "schema": {
        "binding_name": "string",
        "destination": "string",
        "framework": "string"
      },
      "values": {
        "binding_name": "{{binding_name}}",
        "destination": "{{destination}}",
        "framework": "spring-cloud-stream"
      },
      "source": "lens:spring-cloud-stream",
      "confidence": "high"
    }
  },
  {
    "name": "spring-cloud-stream-binding-group",
    "scope": "source",
    "match": {
      "files": ["*.properties", "*.yaml", "*.yml"],
      "strategy": "config-key",
      "key_pattern": "spring\\.cloud\\.stream\\.bindings\\.(?P<binding_name>[\\w.-]+)\\.group\\s*[:=]\\s*(?P<group>\\S+)"
    },
    "emit": {
      "label": "StreamBinding",
      "schema": {
        "binding_name": "string",
        "group": "string",
        "framework": "string"
      },
      "values": {
        "binding_name": "{{binding_name}}",
        "group": "{{group}}",
        "framework": "spring-cloud-stream"
      },
      "source": "lens:spring-cloud-stream",
      "confidence": "high"
    }
  },
  {
    "name": "spring-cloud-stream-stream-listener",
    "scope": "source",
    "match": {
      "files": ["*.java"],
      "strategy": "tree-sitter",
      "tree_sitter": {
        "language": "java",
        "extractor": "query",
        "anchor": "anchor",
        "query": "(method_declaration (modifiers (annotation name: (identifier) @ann (#eq? @ann \"StreamListener\") arguments: (annotation_argument_list (string_literal (string_fragment) @channel)))) name: (identifier) @method_name) @anchor"
      }
    },
    "emit": {
      "label": "MessageConsumer",
      "schema": {
        "message_role": "string",
        "bus": "string",
        "topic": "string",
        "topics": "list",
        "channel": "string",
        "handler": "string",
        "framework": "string"
      },
      "values": {
        "message_role": "consumer",
        "bus": "spring-cloud-stream",
        "topic": "{{channel}}",
        "topics": ["{{channel}}"],
        "channel": "{{channel}}",
        "handler": "{{method_name}}",
        "framework": "spring-cloud-stream"
      },
      "source": "lens:spring-cloud-stream",
      "confidence": "high"
    }
