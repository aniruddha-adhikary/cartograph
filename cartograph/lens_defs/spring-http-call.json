[
  {
    "name": "spring-http-call-get",
    "scope": "source",
    "match": {
      "files": ["*.java"],
      "strategy": "token-line",
      "tokens": ["getForObject", "getForEntity"],
      "extract": "\\.(?:getForObject|getForEntity)\\s*\\(\\s*\"(?P<url>[^\"]+)\""
    },
    "emit": {
      "label": "HttpCall",
      "schema": {"url": "string", "http_method": "string"},
      "values": {"url": "{{url}}", "http_method": "GET"},
      "source": "lens:spring-http-call",
      "confidence": "high"
    }
  },
